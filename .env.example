# ─────────────────────────────────────────────────────────────────────────────
# HonestCyberEval – Environment Variables Template
#
# Copy this file to .env and fill in your real values.
#   cp .env.example .env
#
# .env is git-ignored and must NEVER be committed to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── LLM Provider API Keys (fill in whichever you use) ─────────────────────────

# OpenAI  →  https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Anthropic  →  https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Google Gemini  →  https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=

# Mistral
MISTRAL_API_KEY=

# Together AI / Ollama (optional, for local models)
TOGETHER_API_KEY=

# ── inspect_ai settings (optional overrides) ──────────────────────────────────

# Default model to use when --model flag is not specified
# INSPECT_MODEL=openai/gpt-4o-mini

# Directory where evaluation logs are stored (default: results/)
# INSPECT_LOG_DIR=results/
