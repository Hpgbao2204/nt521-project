# ─────────────────────────────────────────────────────────────────────────────
# HonestCyberEval – Environment Variables Template
#
# Copy this file to .env and fill in your real values.
#   cp .env.example .env
#
# .env is git-ignored and must NEVER be committed to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Ollama (local – no API key needed) ────────────────────────────────────────
# Base URL of your Ollama server. Default is localhost; change if running
# Ollama on a different host or port.
OLLAMA_BASE_URL=http://localhost:11434

# ── LLM Provider API Keys (only needed if you use cloud models) ───────────────

# OpenAI  →  https://platform.openai.com/api-keys
# OPENAI_API_KEY=

# Anthropic  →  https://console.anthropic.com/settings/keys
# ANTHROPIC_API_KEY=

# Google Gemini  →  https://aistudio.google.com/app/apikey
# GOOGLE_API_KEY=

# ── inspect_ai settings (optional overrides) ──────────────────────────────────

# Default model when --model flag is not specified
# INSPECT_MODEL=ollama/qwen2.5-coder:7b

# Directory where evaluation logs are stored (default: results/)
# INSPECT_LOG_DIR=results/
